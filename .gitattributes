# Auto detect text files and perform LF normalization
* text=auto

# JavaScript
*.js text diff=javascript
*.mjs text diff=javascript
*.cjs text diff=javascript

# TypeScript
*.ts text diff=typescript
*.mts text diff=typescript
*.cts text diff=typescript

# JSON
*.json text

# Markdown
*.md text diff=markdown

# HTML
*.html text diff=html

# CSS
*.css text diff=css

# YAML
*.yml text
*.yaml text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files
package-lock.json -diff
