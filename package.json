{
  "name": "bcdtpp",
  "version": "0.1.0",
  "description": "Bounded, Commuting, Discrete-trace Preserving Projections for the 3D de Rham complex on simplicial meshes.",
  "type": "module",
  "main": "src/lib/bcdtpp.js",
  "homepage": "https://github.com/sachn-cs/bounded-commuting-discrete-trace-preserving-projections#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachn-cs/bounded-commuting-discrete-trace-preserving-projections.git"
  },
  "bugs": {
    "url": "https://github.com/sachn-cs/bounded-commuting-discrete-trace-preserving-projections/issues"
  },
  "author": "Sachin",
  "license": "MIT",
  "keywords": [
    "finite-element-method",
    "de-rham-complex",
    "whitney-forms",
    "simplicial-mesh",
    "tetrahedral-mesh",
    "projection",
    "hodge-star",
    "discrete-operators",
    "scientific-computing",
    "numerical-analysis"
  ],
  "module": "dist/bcdtpp.esm.js",
  "unpkg": "dist/bcdtpp.umd.js",
  "jsdelivr": "dist/bcdtpp.umd.js",
  "exports": {
    ".": {
      "types": "./src/lib/bcdtpp.d.ts",
      "default": "./src/lib/bcdtpp.js"
    },
    "./mesh": {
      "types": "./src/lib/mesh.d.ts",
      "default": "./src/lib/mesh.js"
    },
    "./whitney": {
      "types": "./src/lib/whitney.d.ts",
      "default": "./src/lib/whitney.js"
    },
    "./quadrature": {
      "types": "./src/lib/quadrature.d.ts",
      "default": "./src/lib/quadrature.js"
    },
    "./math-utils": {
      "types": "./src/lib/math_utils.d.ts",
      "default": "./src/lib/math_utils.js"
    },
    "./point-locator": {
      "types": "./src/lib/point_locator.d.ts",
      "default": "./src/lib/point_locator.js"
    }
  },
  "types": "src/lib/bcdtpp.d.ts",
  "files": [
    "src/lib/",
    "dist/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "standard src/lib/**/*.js tests/**/*.js",
    "lint:fix": "standard --fix src/lib/**/*.js tests/**/*.js",
    "test": "mocha tests/**/*.test.js",
    "test:watch": "mocha tests/**/*.test.js --watch",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov npm test",
    "docs": "jsdoc2md --files src/lib/**/*.js > docs/api.md",
    "build": "rollup -c rollup.dist.config.js",
    "build:full": "npm run build && npm run docs"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "c8": "^11.0.0",
    "chai": "^5.2.2",
    "jsdoc-to-markdown": "^9.1.1",
    "mocha": "^11.7.6",
    "rollup": "^4.62.2",
    "sinon": "^22.0.0",
    "standard": "^17.1.2"
  },
  "standard": {
    "globals": [
      "describe",
      "it",
      "before",
      "beforeEach",
      "after",
      "afterEach"
    ],
    "ignore": [
      "dist/",
      "coverage/",
      "node_modules/"
    ]
  }
}
